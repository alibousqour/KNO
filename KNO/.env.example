# =========================================================================
# KNO v5.0 Configuration Template
# =========================================================================
# Copy this file to .env and fill in your values
# Then add .env to .gitignore so it's never committed to git
#
# DO NOT commit .env to version control!
# DO NOT save API keys in any other format!
#
# =========================================================================

# =============== CLOUD API KEYS (REQUIRED for cloud features) ===============
# Get these from:
#   - GEMINI_API_KEY: https://aistudio.google.com/app/apikeys
#   - OPENAI_API_KEY: https://platform.openai.com/api-keys  
#   - DEEPSEEK_API_KEY: https://platform.deepseek.com/api/keys
#
# You only need ONE of these for the agent to work
# The system will automatically fall back to another if one fails

GEMINI_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

# =============== SYSTEM SAFETY & PRIVILEGES ===============
# WARNING: Only set to true if you understand the implications
# Enables admin/root privilege escalation at startup

REQUEST_ADMIN=false

# Enable self-healing (AI fixes errors automatically)
ENABLE_SELF_HEALING=true

# =============== AUDIO CONFIGURATION ===============
# Audio device to use (leave blank for default)
AUDIO_DEVICE=

# Audio recording settings
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1
AUDIO_CHUNK_SIZE=1024

# Wake word to listen for
WAKE_WORD=KNO

# Maximum listening time before timeout (seconds)
# If recording runs longer than this, it automatically stops
# Prevents infinite loops and runaway resource usage
# Recommended: 300 (5 minutes)
LISTEN_TIMEOUT_SECONDS=300

# Maximum push-to-talk recording time (seconds)
# Recommended: 60 (1 minute)
PTT_TIMEOUT_SECONDS=60

# =============== LOCAL LLM CONFIGURATION ===============
# Path to Llama model file
# Model formats: .gguf (quantized) or .bin (full precision)
# Download recommended model: https://huggingface.co/models
MODEL_PATH=models/mistral-7b-instruct-v0.1.Q4_K_M.gguf

# Context window size (tokens)
CONTEXT_SIZE=2048

# Maximum tokens to generate per response
MAX_TOKENS=512

# Temperature (0.0=deterministic, 1.0=random)
TEMPERATURE=0.7

# Number of layers to offload to GPU (-1 = auto, 0 = CPU only)
N_GPU_LAYERS=-1

# =============== ERROR RECOVERY & RETRY ===============

# Maximum retry attempts per component before giving up
MAX_RETRIES=3

# Retry backoff multiplier (exponential backoff formula: delay *= 2.0)
RETRY_BACKOFF=2.0

# =============== LOGGING ===============

# Log file location
LOG_FILE=logs/kno.log

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# DEBUG = very verbose (development only)
# INFO = normal operation status
# WARNING = important notices
# ERROR = error messages
# CRITICAL = system failures
LOG_LEVEL=INFO

# =============== PERSISTENT DATA FILES ===============

# File for storing learned experiences and error recovery patterns
MEMORY_FILE=memory.json

# File for storing AI interactions and evolution history
EXPERIENCE_FILE=experience.json

# =============== NOTES ===============
#
# SECURITY BEST PRACTICES:
# 1. Never commit .env to git
# 2. Add .env to .gitignore
# 3. Use unique API keys per environment (dev/staging/prod)
# 4. Rotate API keys regularly
# 5. Store .env in secure location
# 6. Don't share .env files
#
# ENVIRONMENT SETUP:
# 1. cp .env.example .env
# 2. Edit .env with your values
# 3. chmod 600 .env (Linux/Mac - restrict permissions)
# 4. python config.py (verify configuration)
#
# TROUBLESHOOTING:
# - If API key isn't working, check for spaces/quotes
# - Use format: KEY=value (no spaces around =)
# - Values can have spaces, but shouldn't have quotes
# - If audio fails, set explicit AUDIO_DEVICE index
#
# =========================================================================
